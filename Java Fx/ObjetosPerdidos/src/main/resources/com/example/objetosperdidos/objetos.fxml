<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.objetosperdidos.controller.objetosController">
   <children>
      <GridPane layoutX="8.0" layoutY="35.0" prefHeight="90.0" prefWidth="592.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Nombre del objeto" />
            <Label text="Lugar donde se encontró" GridPane.rowIndex="1" />
            <Label text="Estado" GridPane.rowIndex="2" />
            <TextField fx:id="txtNombre" GridPane.columnIndex="1" />
            <TextField fx:id="txtLugar" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <ComboBox fx:id="comboEstado" prefHeight="26.0" prefWidth="277.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <Label layoutX="262.0" layoutY="6.0" text="Objeto Perdido" />
      <ListView fx:id="listView" layoutX="9.0" layoutY="125.0" prefHeight="200.0" prefWidth="528.0" />
      <ButtonBar layoutX="9.0" layoutY="337.0" prefHeight="40.0" prefWidth="528.0">
        <buttons>
          <Button mnemonicParsing="false" onAction="#agregar" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#buscar" text="Buscar" />
            <Button mnemonicParsing="false" onAction="#actualizar" text="Actualizar" />
            <Button mnemonicParsing="false" onAction="#eliminar" text="Eliminar" />
        </buttons>
      </ButtonBar>
   </children>
</AnchorPane>
