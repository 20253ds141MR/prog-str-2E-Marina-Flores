<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.repertoriocanciones.controller.SingController">
   <children>
      <Label text="Registro de Canciones" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Título" />
            <Label text="Artista" GridPane.rowIndex="1" />
            <Label text="Categoría" GridPane.rowIndex="2" />
            <TextField fx:id="txtTitulo" GridPane.columnIndex="1" />
            <TextField fx:id="txtArtista" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <ComboBox fx:id="comboCategoria" prefHeight="26.0" prefWidth="297.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <ListView fx:id="listView" prefHeight="200.0" prefWidth="200.0" />
      <ButtonBar prefHeight="40.0" prefWidth="200.0">
        <buttons>
          <Button mnemonicParsing="false" onAction="#agregar" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#buscar" text="Buscar" />
            <Button mnemonicParsing="false" onAction="#actualizar" text="Actualizar" />
            <Button mnemonicParsing="false" onAction="#eliminar" text="Eliminar" />
        </buttons>
      </ButtonBar>
   </children>
</VBox>
