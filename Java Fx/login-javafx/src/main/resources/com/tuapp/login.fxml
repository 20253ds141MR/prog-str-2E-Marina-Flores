<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="387.0" prefWidth="523.0" spacing="12" styleClass="root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tuapp.LoginController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label styleClass="title" text="Login">
      <font>
         <Font size="18.0" />
      </font></Label>

    <TextField fx:id="txtCorreo" alignment="TOP_LEFT" prefHeight="30.0" prefWidth="235.0" promptText="Correo: " />

    <PasswordField fx:id="txtPassword" promptText="Contraseña (mín. 6 caracteres)" />

    <Button onAction="#onLogin" text="Entrar" />

    <Label fx:id="lblError" styleClass="error-label" wrapText="true" />
</VBox>
