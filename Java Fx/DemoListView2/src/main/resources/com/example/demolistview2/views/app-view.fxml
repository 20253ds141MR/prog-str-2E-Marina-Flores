<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistview2.controllers.AppControllers">
    <children>
        <Label layoutX="36.0" layoutY="27.0" text="Detalles del libro: " />
        <GridPane prefHeight="152.0" prefWidth="600.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Título" />
                <Label text="Autor" GridPane.rowIndex="1" />
                <TextField fx:id="txtTitulo" GridPane.columnIndex="1" />
                <TextField fx:id="txtAutor" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Año" GridPane.rowIndex="2" />
            <Label text="Género" GridPane.rowIndex="3" />
            <TextField fx:id="txtAno" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <TextField GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>
        <HBox prefHeight="32.0" prefWidth="600.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onReload" text="Nuevo" />
                <Button mnemonicParsing="false" onAction="#onAdd" text="Editar" />
            <Button mnemonicParsing="false" text="Eliminar" />
            <Button mnemonicParsing="false" text="Ver detalles" />
            <Button mnemonicParsing="false" text="Exportar reporte" />
            </children>
        </HBox>
        <ListView fx:id="listView" prefHeight="138.0" prefWidth="600.0" />
        <Label fx:id="lblMsg" />
    </children>
</VBox>
